# Supabase (use service role key, not anon key)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Server
PORT=3001
ADMIN_TOKEN=kies_een_geheim_token

# Cache directory for downloaded audio
CACHE_DIR=C:/temp/radio_cache

# Fallback music directory (random tracks when queue is empty)
# Leave empty to disable fallback music
FALLBACK_MUSIC_DIR=
# Preferred: genre-based config JSON (relative to /server)
FALLBACK_GENRES_CONFIG=./config/fallback-genres.json

# Icecast connection
ICECAST_HOST=localhost
ICECAST_PORT=8000
ICECAST_PASSWORD=
ICECAST_MOUNT=/stream

# CORS — allowed frontend origin
FRONTEND_URL=http://localhost:3000

# Keep downloaded files after streaming
KEEP_FILES=false

# Stream output bitrate (higher = better quality, more data)
# Suggested fixed values: 192k (good), 256k (high), 320k (max MP3)
# Or set to "source" for high-quality VBR mode (closest to source feel)
STREAM_BITRATE=256k

# Bridge — download approved requests (Windows only)
DOWNLOAD_PATH=
REKORDBOX_OUTPUT_PATH=

# Optional: Cloudflare named tunnel
# If set, go-live stores RADIO_SERVER_URL.
CLOUDFLARED_TUNNEL_TOKEN=
RADIO_SERVER_URL=

# Optional: ngrok auth token (used as fallback/alternative tunnel)
NGROK_AUTHTOKEN=

# Tunnel mode: ssh (default, avoids DNS-heavy providers) or auto
TUNNEL_MODE=ssh

# Optional: curated subgenre config paths
GENRE_CURATION_CONFIG=./config/genre-curation.json
GENRE_CURATION_PENDING=./config/genre-curation.pending.json

# Optional: LLM batch classifier (scripts/classifyArtists.ts)
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini
