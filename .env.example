# Next.js (kopieer naar .env.local)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_TWITCH_CHANNEL=jouw_kanaal_naam
NEXT_PUBLIC_ADMIN_PASSWORD=kies_een_sterk_wachtwoord
NEXT_PUBLIC_ADMIN_USERNAME=jouw_admin_username
NEXT_PUBLIC_ADMIN_EMAIL=

# Twitch API (voor live detectie, optioneel)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Spotify (playlist browser, https://developer.spotify.com/dashboard)
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=

# Chat media search (GIF + stickers via GIPHY)
# Maak een gratis key aan via developers.giphy.com en zet die alleen server-side.
GIPHY_API_KEY=

# Optional: Last.fm API key (https://www.last.fm/api/account/create)
LASTFM_API_KEY=13e55bcc8d8b85c7a989c4b10f6ce25d

# Radio control server
NEXT_PUBLIC_CONTROL_SERVER_URL=http://localhost:3001
NEXT_PUBLIC_STREAM_URL=http://localhost:8000/stream
